{
    "name": "aiocean/api",
    "description": "AI Tools Discovery Platform — API",
    "type": "project",
    "license": "proprietary",
    "minimum-stability": "stable",
    "require": {
        "php": ">=8.2",
        "robmorgan/phinx": "^0.16.11",
        "resend/resend-php": "^1.3",
        "vlucas/phpdotenv": "^5.6"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "dev": [
            "Composer\\Config::disableProcessTimeout",
            "php -S localhost:8080 -t public/"
        ],
        "migrate": "phinx migrate",
        "rollback": "phinx rollback",
        "seed": "phinx seed:run",
        "test": "phpunit"
    }
}
